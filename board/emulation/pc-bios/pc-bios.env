/* PC (BIOS) default environment */

#include <env/x86.env>

/*
 * Override stdin from x86.env: do NOT include i8042-kbd here.
 * The i8042 controller is not ready during console_init_r() and
 * kbd_reset() leaves it in a bad state if it times out.
 * The preboot command (CONFIG_PREBOOT) adds it later when ready.
 */
stdin=serial
