# PC (BIOS) target - U-Boot loaded by legacy BIOS in 32-bit mode
#

if TARGET_PC_BIOS

config SYS_BOARD
	default "pc-bios"

config SYS_VENDOR
	default "emulation"

config SYS_SOC
	default "bios_pc"

config TEXT_BASE
	default 0x100200

config BOARD_SPECIFIC_OPTIONS
	def_bool y
	select X86_LOAD_FROM_32_BIT
	select BIOS_PC
	select I8259_PIC
	select SYS_NS16550
	help
	  No PCI or storage bus probing; serial and video use BIOS/legacy
	  interfaces only (NS16550 serial, VESA via INT 10h).

endif
