#
# PC (BIOS) target: loaded by MBR at 0x100000. No PCI/storage bus probing;
# serial and video use BIOS/legacy only (NS16550, VESA INT 10h). UEFI (bootefi).
#
# Build the real-mode bootable image:
#   make pc_bios_defconfig && make -j$(nproc)
#   scripts/make-uboot-real.sh
#   -> produces u-boot-real.bin (MBR loads this to 0x100000, jumps in real mode)
#
# Quick QEMU test (with SeaBIOS, display + serial):
#   qemu-system-i386 -display gtk -kernel u-boot-dtb.bin -m 128 -serial stdio
#
CONFIG_X86=y
CONFIG_VENDOR_EMULATION=y
CONFIG_TARGET_PC_BIOS=y
CONFIG_SYS_MALLOC_LEN=0x2000000
CONFIG_NR_DRAM_BANKS=8
CONFIG_DEFAULT_DEVICE_TREE="pc-bios"
CONFIG_DEBUG_UART_BASE=0x3f8
CONFIG_DEBUG_UART_CLOCK=1843200
CONFIG_DEBUG_UART=y
CONFIG_X86_LOAD_FROM_32_BIT=y
CONFIG_I8259_PIC=y
CONFIG_FIT=y
CONFIG_BOOTSTD_FULL=y
CONFIG_BOOTSTAGE=y
CONFIG_SHOW_BOOT_PROGRESS=y
CONFIG_USE_PREBOOT=y
CONFIG_PREBOOT="setenv stdin serial,i8042-kbd"
CONFIG_SYS_CONSOLE_INFO_QUIET=y
CONFIG_LOG=y
CONFIG_LOGF_FUNC=y
CONFIG_DISPLAY_BOARDINFO_LATE=y
# No PCI or storage bus probing; use BIOS interfaces only
# CONFIG_PCI_INIT_R is not set
CONFIG_EFI_LOADER=y
CONFIG_CMD_BOOTEFI=y
CONFIG_CMD_BOOTEFI_BINARY=y
CONFIG_CMD_CPU=y
CONFIG_CMD_MEM_SEARCH=y
CONFIG_CMD_CAT=y
CONFIG_BOOTP_BOOTFILESIZE=y
CONFIG_CMD_TIME=y
CONFIG_CMD_BOOTSTAGE=y
CONFIG_ENV_IS_NOWHERE=y
# BIOS provides SMBIOS tables; don't generate/overwrite them
# CONFIG_GENERATE_SMBIOS_TABLE is not set
CONFIG_REGMAP=y
CONFIG_SYSCON=y
CONFIG_CPU=y
CONFIG_SYS_NS16550_PORT_MAPPED=y
# CONFIG_VIDEO_VESA is not set
CONFIG_FRAMEBUFFER_SET_VESA_MODE=y
CONFIG_FRAMEBUFFER_VESA_MODE_117=y
CONFIG_CONSOLE_SCROLL_LINES=5
CONFIG_CMD_DHRYSTONE=y
